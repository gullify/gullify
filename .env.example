# Gullify Configuration
GULLIFY_SETUP_DONE=false

# MySQL
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=gullify
MYSQL_USER=gullify
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme_root

# Host path to your music library (used by docker-compose volume mount)
# This is the path ON YOUR HOST machine, not inside the container.
# Example: /home/john/music, /mnt/nas/music, /data/music
MUSIC_HOST_PATH=./music

# Container-internal paths (usually no need to change)
MUSIC_BASE_PATH=/music
DATA_PATH=/app/data

# App
# Your domain name — Caddy will automatically get a Let's Encrypt SSL certificate.
# Use a real domain (e.g. music.example.com) for HTTPS, or "localhost" for local dev.
APP_DOMAIN=music.example.com
APP_URL=https://music.example.com
APP_DEBUG=false
# Secret key for encrypting SFTP passwords — change this to a long random string
APP_SECRET=change_me_to_a_long_random_secret_key

# Last.fm API (optional — for artist biographies and similar artists)
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
