# Gullify Configuration
GULLIFY_SETUP_DONE=false

# MySQL
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=gullify
MYSQL_USER=gullify
MYSQL_PASSWORD=gullify_secret
MYSQL_ROOT_PASSWORD=root_secret

# Host path to your music library (used by docker-compose volume mount)
MUSIC_HOST_PATH=/media/music

# Container-internal paths
MUSIC_BASE_PATH=/music
DATA_PATH=/app/data

# App
APP_URL=https://gullify.app
APP_DEBUG=false
# Secret key for encrypting SFTP passwords (change this to a random 32+ char string)
APP_SECRET=change_me_to_a_random_secret_key_at_least_32_chars

# Docker Permissions
PUID=1000
PGID=1000
